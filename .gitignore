# Ignore everything by default. This directory contains credentials, session
# history, telemetry, caches, local MCP settings, and machine-specific state.
*

# Shared repository metadata and documentation.
!/.gitattributes
!/.gitignore
!/CLAUDE.md
!/README.md

# Shared Claude Code templates and utilities.
!/settings.example.json
!/scripts/
!/scripts/**

# User-maintained skills and their templates.
!/skills/
!/skills/*/
!/skills/*/**
